# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/creatorforge

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Razorpay (payments) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier is 3000 emails/month
RESEND_API_KEY=
# Must be a verified domain in your Resend account
FROM_EMAIL=CreatorForge <noreply@yourdomain.com>

# ── Storage (Phase 2 — file uploads) ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ── Client ────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173